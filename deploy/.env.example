# Kopieren nach .env und Werte setzen — NIEMALS die echte .env committen!
WERKOS_DOMAIN=app.example.de
WERKOS_BASE_URL=https://app.example.de
# openssl rand -base64 48
WERKOS_SECRET=
# openssl rand -hex 24  (leer = Admin-API deaktiviert)
WERKOS_ADMIN_TOKEN=
# KI-Beleglesen (Lieferschein-Foto → Positionen). Leer = manueller Modus.
# Anthropic-API-Key (sk-ant-…). Modell optional überschreibbar via WERKOS_AI_MODEL.
WERKOS_AI_KEY=
