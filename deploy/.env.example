# Kopieren nach .env und Werte setzen — NIEMALS die echte .env committen!

# =========================================================================
# VARIANTE A: „Live testen" über Tailscale (docker-compose.tailscale.yml)
# Das System läuft privat im Tailnet, die Website bleibt getrennt (statisch).
# =========================================================================
# Tailscale Auth-Key: Admin-Konsole → Settings → Keys → „Generate auth key"
# (Reusable + optional Tag). Ohne diesen Key startet der Sidecar nicht.
TS_AUTHKEY=
# Hostname im Tailnet → Adresse wird https://<hostname>.<tailnet>.ts.net
TS_HOSTNAME=werkflow-system
# Optionale Extra-Argumente, z. B. --advertise-tags=tag:werkflow
# TS_EXTRA_ARGS=
# System vom Marketing trennen: Marketing-Routen (/ /preise …) leiten hierhin um.
WERKOS_MARKETING_URL=https://daniel-trenz-web.github.io/Mastery

# =========================================================================
# VARIANTE B: Öffentlich mit eigener Domain + TLS (docker-compose.yml, Caddy)
# =========================================================================
WERKOS_DOMAIN=app.example.de
WERKOS_BASE_URL=https://app.example.de
# openssl rand -base64 48
WERKOS_SECRET=
# openssl rand -hex 24  (leer = Admin-API deaktiviert)
WERKOS_ADMIN_TOKEN=
# KI-Beleglesen (Lieferschein-Foto → Positionen) + Website-Texte + Eingangsrechnungs-PDF.
# Anthropic-API-Key (sk-ant-…). Modell optional überschreibbar via WERKOS_AI_MODEL.
WERKOS_AI_KEY=

# --- E-Mail-Versand (Angebote/Rechnungen, Steuerberater-Weiterleitung) ---
# SMTP-Postfach (z. B. IONOS). Leer = manueller Modus (Link teilen).
WERKOS_SMTP_HOST=
WERKOS_SMTP_PORT=587
WERKOS_SMTP_USER=
WERKOS_SMTP_PASS=
WERKOS_SMTP_FROM=
# WERKOS_SMTP_SECURE=true   # implizites TLS (Port 465 statt STARTTLS 587)

# --- Eingehende Webhooks (Rechnungs-Inbox, IDS-Rückgabe, Bank-Push) ---
# Gemeinsames Signatur-Secret; ohne Secret werden diese Webhooks abgelehnt.
# openssl rand -hex 24
WERKOS_INBOUND_SECRET=

# --- Website-Generator: Basis-Domain für generierte Kunden-Websites (optional) ---
WERKOS_SITE_DOMAIN=

# --- Sichere Bankanbindung (PSD2 / Kontoinformationsdienst) ---
# Zugangsdaten des lizenzierten Anbieters (z. B. GoCardless Bank Account Data –
# kostenlos, BaFin-reguliert). NICHT die Bankdaten der Kunden! Der Bank-Login
# läuft bei der jeweiligen Bank (SCA/TAN), read-only. Leer = Anbindung aus.
WERKOS_PSD2_SECRET_ID=
WERKOS_PSD2_SECRET_KEY=
# WERKOS_PSD2_BASE_URL=https://bankaccountdata.gocardless.com

# --- Stripe (echte Zahlung: Kreditkarte via Checkout + SEPA-Lastschrift) ---
# Ohne STRIPE_SECRET läuft der Kauf im manuellen Modus (auf Rechnung).
# Test-Mode: sk_test_… / whsec_… genügen. Live: sk_live_… + Live-Webhook-Secret.
# Webhook-Endpoint in Stripe anlegen: https://<domain>/api/billing/webhook
# Events: checkout.session.completed, customer.subscription.deleted, invoice.payment_failed
WERKOS_STRIPE_SECRET=
WERKOS_STRIPE_WEBHOOK_SECRET=
# Öffentlicher Key (nur falls du später Stripe.js im Frontend nutzt)
WERKOS_STRIPE_PUBLISHABLE=
# Zahlarten (Komma-getrennt). Standard: Karte + SEPA-Lastschrift.
# WERKOS_STRIPE_PAYMENT_METHODS=card,sepa_debit
