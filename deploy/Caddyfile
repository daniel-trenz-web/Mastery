# Caddy: automatisches TLS (Let's Encrypt), HSTS, Reverse-Proxy auf WERKOS.
{$WERKOS_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
	}

	# Große Uploads (Voll-Backup-Restore) zulassen
	request_body {
		max_size 512MB
	}

	reverse_proxy werkos:4000
}
